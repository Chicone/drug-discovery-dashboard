; MARTINI 3 — Energy Minimization
integrator      = steep
emtol           = 30.0
emstep          = 0.008
nsteps          = 100000

; Neighbour searching
cutoff-scheme   = Verlet
nstlist         = 20
rlist           = 1.1

; Electrostatics
coulombtype     = Reaction-Field
epsilon_rf      = 15
rcoulomb        = 1.1

; Van der Waals
vdw-type        = Cut-off
rvdw            = 1.1

; Martini specifics
pbc             = xyz
constraints     = none


